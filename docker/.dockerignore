# Build / packaging artefacts
build/
dist/
*.egg-info/
.eggs/
wheels/

# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Local virtual environments
.venv/
venv/
env/
.env

# IDE / editor metadata
.idea/
.vscode/

# VCS metadata (kept out of build context to keep it small)
.git/
.gitignore

# Documentation site output
site/
docs/_build/

# Generated protobuf stubs (regenerated inside the image by build.sh)
**/*_pb2.py
**/*_pb2_grpc.py

# Misc
*.log
*.tmp
.DS_Store
